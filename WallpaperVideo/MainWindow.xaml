<Window x:Class="WallpaperVideo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wallpaper Vídeo" Height="450" Width="800"
        Background="#161A22"
        Foreground="#E7EDF6"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        LocationChanged="SaveConfig"
        SizeChanged="SaveConfig">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#161A22"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#1E2531"/>
        <SolidColorBrush x:Key="InputBrush" Color="#222B39"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3A4659"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E7EDF6"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AAB6C7"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10" Background="{StaticResource AppBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="Pasta vídeos:" VerticalAlignment="Center" Width="85"/>
            <TextBox x:Name="txtPath" Grid.Column="1" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="True"/>
            <Button Content="..." Grid.Column="2" Width="30" Height="26" Click="BtnSelectFolder_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="Path mpv:" VerticalAlignment="Center" Width="85"/>
            <TextBox x:Name="txtMpvPath" Grid.Column="1" Margin="5,0"
                 VerticalContentAlignment="Center" IsReadOnly="True"
                 Text="D:\programas\executaveis\mpv"/>
            <Button Content="..." Grid.Column="2" Width="30" Height="26" Click="BtnSelectMpv_Click"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="chkRandom" Content="Aleatório" VerticalAlignment="Center" IsChecked="True"
                      Checked="SaveConfig" Unchecked="SaveConfig"/>
            <TextBox x:Name="txtMinutes" Width="40" Margin="10,0,5,0" Text="10"
                     IsEnabled="{Binding IsChecked, ElementName=chkRandom}"
                     TextChanged="SaveConfig"/>
            <Label Content="minutos" Margin="0,0,20,0" Foreground="{StaticResource MutedTextBrush}"/>
            <CheckBox x:Name="chkStartWindows" Content="Iniciar com o Windows" VerticalAlignment="Center" Click="ChkStartWindows_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsVideos">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Margin="5" Width="150" Background="{StaticResource PanelBrush}" CornerRadius="3" MouseLeftButtonDown="PlayVideo_Click" Cursor="Hand">
                            <StackPanel>
                                <Image Source="{Binding Thumbnail}" Height="80" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="LowQuality"/>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="11"/>
                                    <Button Grid.Column="1" Content="X" Foreground="White" Background="#E74C3C"
                                            Width="18" Height="18" Margin="4,0,0,0"
                                            BorderBrush="#9F2A21" BorderThickness="1"
                                            Click="RemoveVideo_Click" CommandParameter="{Binding}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="2"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
